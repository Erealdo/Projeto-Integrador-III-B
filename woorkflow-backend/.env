# ============================================================
# WoorkFlow — Variáveis de Ambiente
# Renomeie este arquivo para .env e preencha os valores
# NUNCA suba o arquivo .env para o Git!
# ============================================================

# Servidor
PORT=3001

# Banco de dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1906
DB_NAME=woorkflow

# JWT — troque por uma string longa e aleatória
JWT_SECRET=troque_por_uma_chave_secreta_muito_longa_aqui
JWT_EXPIRES_IN=7d

# Ambiente
NODE_ENV=development
